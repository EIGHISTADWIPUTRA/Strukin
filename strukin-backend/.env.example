# ─────────────────────────────────────────────────────────────────────────────
# Strukin Backend — Environment Variables
# Copy this file to .env and fill in your real credentials.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# Supabase project URL (e.g. https://xxxx.supabase.co)
SUPABASE_URL=

# Supabase service_role secret key (used server-side only, bypasses RLS for admin ops)
SUPABASE_SERVICE_ROLE_KEY=

# Supabase JWT secret — found in: Project Settings → API → JWT Secret
# Used to verify user-issued access tokens offline (no network call needed)
SUPABASE_JWT_SECRET=

# Alibaba Cloud DashScope — Qwen3-VL
DASHSCOPE_API_KEY=
# Model ID (default: qwen3-vl-30b-a3b-instruct)
DASHSCOPE_MODEL=qwen3-vl-30b-a3b-instruct
