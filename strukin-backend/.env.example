# ─────────────────────────────────────────────────────────────────────────────
# Strukin Backend — Environment Variables
# Copy this file to .env and fill in your real credentials.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# Supabase project URL (e.g. https://xxxx.supabase.co)
SUPABASE_URL=

# Supabase service_role key (server-side only, bypasses RLS for admin ops)
SUPABASE_SERVICE_ROLE_KEY=

# Supabase anon/public key — used as apikey header when fetching JWKS
# Same value as NEXT_PUBLIC_SUPABASE_ANON_KEY in the web app
SUPABASE_ANON_KEY=

# SUPABASE_JWT_SECRET is no longer required.
# JWT tokens are now verified using the JWKS endpoint (ES256):
#   https://<project-ref>.supabase.co/auth/v1/jwks

# Alibaba Cloud DashScope — Qwen3-VL
DASHSCOPE_API_KEY=
# Model ID (default: qwen3-vl-30b-a3b-instruct)
DASHSCOPE_MODEL=qwen3-vl-30b-a3b-instruct
