# ─────────────────────────────────────────────────────────────────────────────
# Strukin Backend — Environment Variables
# Copy this file to .env and fill in your real credentials.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# Supabase project URL (e.g. https://xxxx.supabase.co)
SUPABASE_URL=

# Supabase service_role key (server-side only, bypasses RLS)
# Dashboard → API Keys → Secret keys (sb_secret_...)
SUPABASE_SERVICE_ROLE_KEY=

# Supabase anon/public key — needed for JWKS fetch and same as web's NEXT_PUBLIC_SUPABASE_ANON_KEY
# Dashboard → API Keys → Publishable key (sb_publishable_...)
SUPABASE_ANON_KEY=

# Alibaba Cloud DashScope — Qwen3-VL
DASHSCOPE_API_KEY=
# Model ID (default: qwen3-vl-30b-a3b-instruct)
DASHSCOPE_MODEL=qwen3-vl-30b-a3b-instruct
